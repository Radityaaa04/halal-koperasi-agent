# ===========================================
# LLM Provider Configuration
# ===========================================
# Primary: NVIDIA NIM (Recommended - free tier available)
LLM_PROVIDER=nvidia_nim
# Get API key from: https://build.nvidia.com/explore/discover
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.1-8b-instruct

# Embedding Provider
EMBEDDING_PROVIDER=nvidia_nim
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Reranker Provider
RERANKER_PROVIDER=nvidia_nim
RERANKER_MODEL=nvidia/rerank-qa-mistral-4b
# Reranker Provider
# ===========================================
RERANKER_PROVIDER=nvidia_nim
RERANKER_MODEL=nvidia/rerank-qa-mistral-4b

# ===========================================
# ChromaDB
# ===========================================
CHROMA_HOST=http://localhost:8000
CHROMA_COLLECTION_PREFIX=halal_regulations

# ===========================================
# Vector Store Config
# ===========================================
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
SIMILARITY_THRESHOLD=0.5

# ===========================================
# RAG Config
# ===========================================
MAX_CONTEXT_TOKENS=4000
CITATION_MAX_LENGTH=200
ENABLE_HYBRID_SEARCH=true
ENABLE_RERANKING=true

# ===========================================
# Document Processing
# ===========================================
OCR_LANGUAGES=["en", "id"]
OCR_CONFIDENCE_THRESHOLD=0.7
PDF_DPI=200

# ===========================================
# Agent Config
# ===========================================
MAX_ITERATIONS=3
HUMAN_REVIEW_THRESHOLD=80.0
CRITICAL_GAPS_THRESHOLD=0

# ===========================================
# Evaluation
# ===========================================
EVAL_BATCH_SIZE=10
HALLUCINATION_CHECK_MODEL=meta/llama-3.1-8b-instruct

# ===========================================
# Streamlit
# ===========================================
STREAMLIT_PORT=8501
STREAMLIT_HOST=0.0.0.0

# ===========================================
# Paths
# ===========================================
DATA_DIR=./data
KB_DIR=./data/regulatory_chunks
SYNTHETIC_DIR=./data/synthetic_docs
TEMPLATES_DIR=./data/templates
EVAL_DIR=./data/eval
PROFILES_DIR=./data/koperasi_profiles